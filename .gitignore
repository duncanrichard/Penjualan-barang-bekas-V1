# Environment
.env
.env.*
!.env.example

# Dependencies
/vendor/
/node_modules/

# Laravel generated files
/public/build/
/public/hot
/public/storage

# Storage runtime files
/storage/*.key
/storage/app/private/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/testing/*
/storage/framework/views/*
/storage/logs/*
/storage/pail/

# Pertahankan struktur folder storage
!/storage/app/private/.gitignore
!/storage/framework/cache/.gitignore
!/storage/framework/sessions/.gitignore
!/storage/framework/testing/.gitignore
!/storage/framework/views/.gitignore
!/storage/logs/.gitignore

# Bootstrap cache
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Testing
.phpunit.result.cache
.phpunit.cache/
coverage/
.phpunit.cache

# IDE dan editor
/.fleet/
/.idea/
/.nova/
/.vscode/
/.zed/
.phpactor.json

# Authentication
/auth.json

# Laravel Homestead
Homestead.json
Homestead.yaml

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini

# Log files
*.log

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Optional local database
*.sqlite
*.sqlite3

# Backup files
*.backup
*.bak
.env.backup
.env.production
